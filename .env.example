# ---- Database (Neon Postgres) ----
# Pooled connection string (used by the app at runtime).
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/collabedit?sslmode=require"
# Direct (un-pooled) connection — used by `prisma migrate`.
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/collabedit?sslmode=require"

# ---- Auth.js ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"

# ---- Realtime sync (WebSocket server) ----
# URL the browser connects to. ws:// locally, wss:// in production (Railway).
NEXT_PUBLIC_SYNC_URL="ws://localhost:1234"
# Shared secret used to sign short-lived room tokens the WS server verifies.
# MUST match SYNC_JWT_SECRET on the WS server. Keep it server-only (no NEXT_PUBLIC_).
SYNC_JWT_SECRET="replace-with-another-long-random-secret"

# ---- AI (Google Gemini) ----
# From https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# ---- WS server only (server/.env or Railway vars) ----
# The WS server needs DATABASE_URL + SYNC_JWT_SECRET (same values as above).
